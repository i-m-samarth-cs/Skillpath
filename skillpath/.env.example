# ── Anthropic (for Coach Agent) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── AI/ML API (for Gap Analyst + HR Reporter) ────────────────────────────────
# Get from: https://aimlapi.com  |  Coupon: claim on lablab.ai (10 USD free)
AIML_API_KEY=YOUR_AIML_KEY_HERE
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=google/gemma-3-4b-it

# ── Featherless AI (for Curriculum Architect + Progress Tracker) ─────────────
# Get from: https://featherless.ai  |  Promo code: BOA26  (25 USD free)
FEATHERLESS_API_KEY=YOUR_FEATHERLESS_KEY_HERE
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# ── Band Platform ─────────────────────────────────────────────────────────────
# Agent credentials are now loaded from agent_config.yaml instead of .env.
# Copy agent_config.yaml.example to agent_config.yaml and fill in your values.
# 1. Sign up at https://app.band.ai
# 2. Apply promo code BANDHACK26 for free Pro month
# 3. Create 5 agents under Settings → Agents
# 4. Copy each agent's ID and API key into agent_config.yaml

BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_REST_URL=https://app.band.ai

# Gap Analyst agent credentials
GAP_ANALYST_AGENT_ID=YOUR_GAP_ANALYST_ID
GAP_ANALYST_API_KEY=YOUR_GAP_ANALYST_KEY

# Curriculum Architect agent credentials
CURRICULUM_AGENT_ID=YOUR_CURRICULUM_ID
CURRICULUM_API_KEY=YOUR_CURRICULUM_KEY

# Coach Agent credentials
COACH_AGENT_ID=YOUR_COACH_ID
COACH_API_KEY=YOUR_COACH_KEY

# Progress Tracker agent credentials
TRACKER_AGENT_ID=YOUR_TRACKER_ID
TRACKER_API_KEY=YOUR_TRACKER_KEY

# HR Reporter agent credentials
REPORTER_AGENT_ID=YOUR_REPORTER_ID
REPORTER_API_KEY=YOUR_REPORTER_KEY
